# ========================================
# FlavourFinder Server Configuration (.env)
# ========================================
# SETUP INSTRUCTIONS:
# 1. Copy this file to create a real .env file
# 2. Add .env to .gitignore (DO NOT commit to git!)
# 3. Fill in your actual credentials below
# 4. Restart the server after making changes
# ========================================

# ---- SERVER CONFIGURATION ----
PORT=5000
NODE_ENV=development

# ---- DATABASE CONFIGURATION (REQUIRED) ----
# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/flavorfinder
#
# MongoDB Atlas (recommended for production):
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/flavorfinder
MONGODB_DB_NAME=flavorfinder

# ---- JWT CONFIGURATION (REQUIRED) ----
# Generate a random secret:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

# ---- EMAIL CONFIGURATION (OTP System) ----
# Option 1: ETHEREAL (Automatic - No setup needed for testing)
# Just leave GMAIL_USER and GMAIL_APP_PASSWORD commented out
# System will auto-create Ethereal account

# Option 2: GMAIL (Production Ready)
# Step 1: Go to https://myaccount.google.com/security
# Step 2: Enable "2-Step Verification"
# Step 3: Go to "App passwords" (appears after 2-Step enabled)
# Step 4: Select "Mail" and "Windows Computer"
# Step 5: Copy the 16-character password below
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ---- FRONTEND CONFIGURATION (REQUIRED IN PRODUCTION) ----
FRONTEND_URL=http://localhost:3000

# ---- STRIPE CONFIGURATION (Optional - for payments) ----
# STRIPE_SECRET_KEY=your_stripe_secret_key
# STRIPE_PUBLIC_KEY=your_stripe_public_key

# ---- AWS S3 CONFIGURATION (Optional - for image uploads) ----
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_S3_BUCKET=flavor-finder-bucket

# ---- GOOGLE GEMINI API (Optional - for AI features) ----
# GEMINI_API_KEY=your_gemini_api_key

# ========================================
# TIPS:
# ========================================
# - For Gmail App Password: Use the 16-character password, NOT your Gmail password
# - OTP Email System: Uses Ethereal (auto) OR Gmail (with above credentials)
# - Development: Ethereal can show OTP in server console logs
# - Production: Use Gmail for real email delivery
# - Check server console for OTP logs: "🔐 OTP: XXXXXX"
# - Max OTP attempts: Validation only checks if OTP matches
# - OTP Validity: 5 minutes (change in authController.js if needed)
# - Readiness checks: /health and /ready
