# Frontend Environment Variables (Render Static Site)

# Backend public URL (no trailing /api)
# Local: http://localhost:5000
# Production: https://flavorfinder-api.onrender.com
VITE_API_URL=http://localhost:5000

# Public Mapbox token (starts with pk_)
VITE_MAPBOX_TOKEN=pk_test_xxxxx

# Optional maps/AI integrations for frontend features
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Mode hint for client code
VITE_ENV=development

