# Frontend Environment Variables

# API Configuration - IMPORTANT: Change this to your backend URL
# For local development:
VITE_API_URL=http://localhost:5000
# For testing on different machine: http://192.168.YOUR.IP:5000
# For production: https://your-backend.onrender.com

# Mapbox API Token (RECOMMENDED - Better for Zomato-like UI)
# Get your free token from: https://account.mapbox.com/tokens/
# MAKE SURE it's a PUBLIC token (starts with pk_)
VITE_MAPBOX_TOKEN=pk_test_xxxxx

# Alternative: Google Maps API Key
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Google Gemini API (for AI Foodie Assistant)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Environment
VITE_ENV=development

